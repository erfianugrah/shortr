# shortr — environment configuration
#
# Copy to .env (gitignored) for local dev.
# In production these are set via `flyctl secrets set`.

# Required: bearer token guarding /api/*. Generate with `openssl rand -hex 32`.
ADMIN_TOKEN=

# Required: full origin where the redirect service is reachable.
# Used to generate short URLs in the dashboard.
PUBLIC_BASE_URL=http://localhost:8080

# Optional: HTTP port. Default 8080.
PORT=8080

# Optional: SQLite database path. Default ./shortr.db.
DB_PATH=./shortr.db

# Optional: log level (debug | info | warn | error). Default info.
LOG_LEVEL=info

# Optional: log format (text | json). Default json in prod, text in dev.
LOG_FORMAT=text

# Optional: salt for hashing client IPs in click events.
# Random per-deploy is fine; rotating invalidates IP-based dedup.
IP_HASH_SALT=

# Optional: max click event buffer. Default 1024.
# Click events drop (with metric) when this fills.
CLICK_BUFFER=1024

# --- Litestream (production only — see deploy/litestream.yml) ---
# Set automatically by `flyctl storage create`:
# AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY,
# BUCKET_NAME, AWS_REGION, AWS_ENDPOINT_URL_S3
